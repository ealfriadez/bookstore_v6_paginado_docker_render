# Copia este archivo como .env y completa los valores reales
# El archivo .env NUNCA debe subirse al repositorio

# ─── Base de datos ───────────────────────────────────────────
# Para IntelliJ (sin Docker): apunta a localhost
DB_URL=jdbc:postgresql://localhost:5432/bookstore_db
DB_USERNAME=postgres
DB_PASSWORD=root

# Usadas por el servicio db en docker-compose
POSTGRES_DB=bookstore_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# ─── JWT ─────────────────────────────────────────────────────
# genera un secreto seguro con: openssl rand -base64 64
JWT_SECRET=reemplazaConUnaClaveAleatoriaSeguraDe64CaracteresMinimo
JWT_EXPIRATION=86400000

# ─── Servidor ────────────────────────────────────────────────
SERVER_PORT=8083

# ─── JPA ─────────────────────────────────────────────────────
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# ─── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
